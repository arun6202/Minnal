@page "/"
@inject IWorkbenchService Workbench
@inject IAiService Ai
@inject IHttpExecutionService Http

@{
    var snapshot = _view.Snapshot;
    var active = snapshot.ActiveRequest;
    var response = snapshot.Response;
    var model = snapshot.Model;
    var hook = snapshot.Hook;
    var platform = snapshot.Platform;
    var telemetry = _view.Telemetry;
    var storage = _view.Storage;
}

<main class="workbench @(_whyExpanded ? "why-expanded" : null)">
    <header class="topbar">
        <div class="brand">
            <strong>Minnal</strong>
            <span>Never Settle</span>
        </div>
        <div class="intent">
            <span class="prompt">&gt;</span>
            <span>@snapshot.Intent</span>
        </div>
        <button class="primary" @onclick="OnRunAsync" disabled="@_running">@(_running ? "Running..." : "Run")</button>
        <button class="secondary" @onclick="OnExplainAsync" disabled="@(_explaining || _liveResponse is null)">@(_explaining ? "Explaining..." : "Explain")</button>
    </header>

    <section class="left-rail">
        <div class="rail-title">Requests</div>
        @foreach (var req in snapshot.Requests)
        {
            <article class="request-item @(req.Name == active.Name ? "active" : null)">
                <div>
                    <span class="method">@req.Method</span>
                    <strong>@req.Name</strong>
                </div>
                <p>@req.Url</p>
                <small>@req.Status</small>
            </article>
        }

        <article class="model-panel">
            <div class="rail-title">Model</div>
            <strong>@model.Mode</strong>
            <p>@model.Backend</p>
            <small>AI: @Ai.State - @Ai.StatusText</small>
        </article>

        <article class="model-panel compact">
            <div class="rail-title">Platform</div>
            <strong>@platform.PrimaryTarget</strong>
            <p>@platform.UiHost</p>
            <small>@platform.FutureTargets</small>
        </article>
    </section>

    <section class="request-surface">
        <div class="request-line">
            <select class="method-box method-select" @bind="_methodText" disabled="@(_sending || _running)">
                <option value="GET">GET</option>
                <option value="POST">POST</option>
                <option value="PATCH">PATCH</option>
                <option value="PUT">PUT</option>
                <option value="DELETE">DELETE</option>
            </select>
            <input class="url-box url-input" @bind="_urlText" @bind:event="oninput" disabled="@(_sending || _running)" />
            <button class="primary" @onclick="OnSendAsync" disabled="@_sending">@(_sending ? "Sending..." : "Send")</button>
        </div>

        <div class="request-grid">
            <article class="panel">
                <div class="panel-title">Headers</div>
                <p>Authorization: @active.Auth</p>
                <p>Content-Type: application/json</p>
            </article>
            <article class="panel">
                <div class="panel-title">Body</div>
                <code>&#123; "scope": "workspace:write" &#125;</code>
            </article>
        </div>

        <article class="response-panel">
            @if (_liveResponse is not null)
            {
                <div class="response-meta">
                    <strong>@_liveResponse.StatusCode</strong>
                    <span>@_liveResponse.DurationMs ms</span>
                    <span>@((_liveResponse.SizeBytes / 1024.0).ToString("0.0")) KB</span>
                    @if (_liveResponse.IsError) { <span class="warn">@_liveResponse.ErrorMessage</span> }
                </div>
                <p>@_liveResponse.Body</p>
            }
            else if (_sending)
            {
                <p>Sending...</p>
            }
            else
            {
                <div class="response-meta">
                    <strong>@response.StatusCode</strong>
                    <span>@response.DurationMs ms</span>
                    <span>@response.SizeKb.ToString("0.0") KB</span>
                </div>
                <p>@response.Summary</p>
            }
        </article>

        <footer class="promote-strip">
            <span>Zero persistence until Promote</span>
            <button class="secondary">Save</button>
            <button class="promote">Promote</button>
        </footer>
    </section>

    <aside class="why-drawer">
        <div class="drawer-title">
            <span class="rail-title">Why</span>
            <button class="icon-button" title="@(_whyExpanded ? "Dock" : "Expand")" @onclick="ToggleWhyDrawer">
                @(_whyExpanded ? "Dock" : "Expand")
            </button>
        </div>
        <div class="accordion-stack">
            <details class="accordion-section evidence-section" open>
                <summary>Evidence</summary>
                <div class="accordion-body evidence-body">
                    @if (!string.IsNullOrEmpty(_aiExplanation))
                    {
                        <p class="evidence-text">@_aiExplanation</p>
                    }
                    else if (_explaining)
                    {
                        <p class="evidence-text">Explaining...</p>
                    }
                    else
                    {
                        <p class="evidence-text">Hit Send then Explain to see AI analysis.</p>
                    }
                </div>
            </details>

            <details class="accordion-section" open>
                <summary>Next Action</summary>
                <div class="accordion-body">
                    <p class="drawer-text">Refresh credentials, replay once, keep the failed response attached to history.</p>
                </div>
            </details>

            <details class="accordion-section">
                <summary>Hook Review</summary>
                <div class="accordion-body">
                    <strong>@hook.Phase: @hook.Name</strong>
                    <p class="drawer-text">@hook.Capability</p>
                    <small>@hook.Verdict</small>
                </div>
            </details>

            <details class="accordion-section">
                <summary>Memory Policy</summary>
                <div class="accordion-body">
                    <strong>&lt; @model.ColdTargetMb MB cold</strong>
                    <p class="drawer-text">&lt; @model.WarmTargetMb MB warm, excluding model mmap</p>
                    <small>@model.UnloadPolicy</small>
                </div>
            </details>
        </div>
    </aside>

    <footer class="statusbar">
        <span class="ok">Offline</span>
        <span>SQLite: ready</span>
        <span class="@(Ai.IsReady ? "ok" : "warn")">AI: @Ai.State</span>
        <span class="@(telemetry.ProcessTreeMb > model.ColdTargetMb ? "warn" : "ok")">Tree: @telemetry.ProcessTreeMb MB / @model.ColdTargetMb MB target</span>
        <span>Host: @telemetry.HostProcessMb MB</span>
        <span>WebView2: @telemetry.WebView2TreeMb MB</span>
        <span>Heap: @telemetry.ManagedHeapMb MB</span>
        <span>Requests: @storage.RequestCount</span>
        <span>Bodies: @storage.ResponseBodiesStored</span>
    </footer>
</main>

@code {
    private Minnal.AppModel.WorkbenchView _view = default!;
    private HttpResultView? _liveResponse;
    private string _aiExplanation = "";
    private string _methodText = "GET";
    private string _urlText = "";
    private bool _sending;
    private bool _explaining;
    private bool _running;
    private bool _whyExpanded;

    protected override void OnInitialized()
    {
        _view = Workbench.GetView();
        _methodText = _view.Snapshot.ActiveRequest.Method;
        _urlText = _view.Snapshot.ActiveRequest.Url;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _ = Task.Run(async () =>
        {
            await Ai.LoadAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task OnSendAsync()
    {
        _sending = true;
        _liveResponse = null;
        _aiExplanation = "";
        _liveResponse = await Http.SendAsync(_methodText, _urlText.Trim());
        _sending = false;
    }

    private async Task OnExplainAsync()
    {
        if (_liveResponse is null) return;
        _explaining = true;
        _aiExplanation = await Ai.ExplainAsync(_liveResponse.Body);
        _explaining = false;
    }

    private async Task OnRunAsync()
    {
        _running = true;
        await OnSendAsync();
        await OnExplainAsync();
        _running = false;
    }

    private void ToggleWhyDrawer()
    {
        _whyExpanded = !_whyExpanded;
    }
}
